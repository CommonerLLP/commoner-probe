{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CommonerLLP/commoner-probe/schemas/v1/manifest_mospi.json",
  "title": "manifest.jsonl — MoSPI eSankhyiki API pull",
  "description": "One eSankhyiki data pull: the exact endpoint and query params used, row count, and sha256 of the tidy CSV written under csv/. Filter codes in params are dataset-specific API codes (e.g. PLFS state_code 99 = All India) read from the dataset's filter endpoint.",
  "type": "object",
  "required": [
    "key",
    "kind",
    "record_type",
    "source",
    "dataset",
    "endpoint",
    "params",
    "rows",
    "csv_path",
    "sha256",
    "fetched_at",
    "probed_at"
  ],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^MOSPI\\|[A-Z0-9]+\\|[a-f0-9]{12}$"
    },
    "kind": { "type": "string", "const": "mospi_pull" },
    "record_type": { "type": "string", "const": "mospi_pull" },
    "source": { "type": "string", "const": "api.mospi.gov.in" },
    "dataset": { "type": "string" },
    "endpoint": { "type": "string" },
    "params": { "type": "object" },
    "rows": { "type": "integer", "minimum": 0 },
    "csv_path": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "truncated": { "type": "boolean" },
    "fetched_at": { "type": "string" },
    "probed_at": { "type": "string" }
  }
}
