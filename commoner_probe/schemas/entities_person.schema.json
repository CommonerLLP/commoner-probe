{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CommonerLLP/commoner-probe/schemas/v1/entities_person.json",
  "title": "entities/people.jsonl record",
  "description": "Stable identity record for a politician, minister, bureaucrat, or expert witness.",
  "type": "object",
  "required": ["entity_id", "canonical_name", "alt_names", "primary_kind", "first_seen_at", "last_updated_at"],
  "properties": {
    "entity_id": { "type": "string", "pattern": "^PERSON_[0-9a-f]{8}_" },
    "canonical_name": { "type": "string" },
    "alt_names": { "type": "array", "items": { "type": "string" } },
    "primary_kind": { "type": "string", "enum": ["politician", "bureaucrat", "expert_witness", "unknown"] },
    "first_seen_at": { "type": "string" },
    "last_updated_at": { "type": "string" }
  }
}
