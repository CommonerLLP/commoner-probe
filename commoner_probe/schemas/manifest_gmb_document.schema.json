{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CommonerLLP/commoner-probe/schemas/v1/manifest_gmb_document.json",
  "title": "manifest.jsonl — Gujarat Maritime Board public-disclosure artifact",
  "description": "One Gujarat Maritime Board (gmbports.org) acquisition record: a page HTML snapshot, a discovered PDF, or a derived CSV.",
  "type": "object",
  "required": [
    "key",
    "kind",
    "record_type",
    "source_family",
    "source_name",
    "publisher",
    "document_class",
    "filename",
    "dest",
    "url",
    "status",
    "media_type",
    "fetched_at",
    "probed_at"
  ],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^GMB\\|[a-z0-9-]+\\|.+$"
    },
    "kind": {
      "type": "string",
      "const": "gmb_document"
    },
    "record_type": {
      "type": "string",
      "const": "gmb_document"
    },
    "source_family": {
      "type": "string",
      "const": "gmb"
    },
    "source_name": {
      "type": "string",
      "enum": [
        "admin-reports",
        "publications-misc",
        "financials",
        "traffic",
        "tariff",
        "circulars",
        "tenders",
        "rti",
        "vision-2047",
        "news-articles"
      ]
    },
    "publisher": {
      "type": "string"
    },
    "document_class": {
      "type": "string",
      "enum": [
        "admin-report",
        "publication",
        "financial",
        "traffic-page",
        "traffic-table",
        "tariff",
        "circular",
        "tender",
        "rti",
        "vision",
        "news"
      ]
    },
    "filename": {
      "type": "string"
    },
    "dest": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "status": {
      "type": "string",
      "enum": [
        "dry_run",
        "downloaded",
        "skipped_exists",
        "derived",
        "robots_blocked",
        "fetch_error"
      ]
    },
    "media_type": {
      "type": "string"
    },
    "fiscal_year": {
      "type": ["string", "null"]
    },
    "language": {
      "type": ["string", "null"],
      "enum": ["en", "gu", null]
    },
    "note": {
      "type": ["string", "null"]
    },
    "discovered_on": {
      "type": ["string", "null"]
    },
    "source_last_modified": {
      "type": ["string", "null"]
    },
    "source_last_modified_raw": {
      "type": ["string", "null"]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "http_status": {
      "type": ["integer", "null"]
    },
    "error": {
      "type": ["string", "null"]
    },
    "fetched_at": {
      "type": "string"
    },
    "probed_at": {
      "type": "string"
    }
  }
}
