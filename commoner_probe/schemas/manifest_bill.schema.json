{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CommonerLLP/commoner-probe/schemas/v1/manifest_bill.json",
  "title": "manifest.jsonl — Bill / legislation record",
  "description": "One sansad.in bill record (api_rs/legislation/getBills).",
  "type": "object",
  "required": [
    "key",
    "kind",
    "record_type",
    "source",
    "house",
    "fetch_status",
    "probed_at"
  ],
  "properties": {
    "key": { "type": "string", "pattern": "^BILL\\|[a-z]+\\|.+$" },
    "kind": { "type": "string", "const": "bill_record" },
    "record_type": { "type": "string", "const": "bill_record" },
    "source": { "type": "string" },
    "house": { "type": "string" },
    "bill_no": { "type": ["string", "integer", "null"] },
    "bill_name": { "type": ["string", "null"] },
    "bill_type": { "type": ["string", "null"] },
    "bill_category": { "type": ["string", "null"] },
    "ministry": { "type": ["string", "null"] },
    "bill_year": { "type": ["integer", "string", "null"] },
    "introduced_house": { "type": ["string", "null"] },
    "introduced_by": { "type": ["string", "null"] },
    "introduced_date": { "type": ["string", "null"] },
    "introduced_file": { "type": ["string", "null"] },
    "passed_ls_date": { "type": ["string", "null"] },
    "passed_ls_file": { "type": ["string", "null"] },
    "passed_rs_date": { "type": ["string", "null"] },
    "passed_rs_file": { "type": ["string", "null"] },
    "passed_both_houses_file": { "type": ["string", "null"] },
    "referred_to_committee_date": { "type": ["string", "null"] },
    "report_presented_date": { "type": ["string", "null"] },
    "report_file": { "type": ["string", "null"] },
    "act_no": { "type": ["string", "integer", "null"] },
    "act_year": { "type": ["integer", "string", "null"] },
    "assent_date": { "type": ["string", "null"] },
    "gazetted_file": { "type": ["string", "null"] },
    "synopsis_file": { "type": ["string", "null"] },
    "errata_file": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "fetch_status": { "type": "string", "enum": ["ok", "dry_run", "fetch_error"] },
    "api_url": { "type": "string" },
    "fetched_at": { "type": "string" },
    "probed_at": { "type": "string" },
    "error": { "type": "string" }
  }
}
