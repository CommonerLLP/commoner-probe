{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CommonerLLP/commoner-probe/schemas/v1/manifest_budget.json",
  "title": "manifest.jsonl — Public-finance (budget) raw source file",
  "description": "One Union Budget / RBI State-Finances raw source-file acquisition record.",
  "type": "object",
  "required": [
    "key",
    "kind",
    "record_type",
    "source_family",
    "source_name",
    "publisher",
    "fiscal_year",
    "document_type",
    "demand_no",
    "section",
    "filename",
    "dest",
    "url",
    "status",
    "media_type",
    "fetched_at",
    "probed_at"
  ],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^BUDGET\\|[a-z-]+\\|.+$"
    },
    "kind": {
      "type": "string",
      "const": "budget_source_file"
    },
    "record_type": {
      "type": "string",
      "const": "budget_source_file"
    },
    "source_family": {
      "type": "string",
      "const": "budget"
    },
    "source_name": {
      "type": "string",
      "enum": ["union-budget", "rbi-state-finances"]
    },
    "publisher": {
      "type": "string"
    },
    "fiscal_year": {
      "type": "string"
    },
    "document_type": {
      "type": "string",
      "enum": ["demand_for_grants", "state_finances_study"]
    },
    "demand_no": {
      "type": ["string", "null"]
    },
    "section": {
      "type": ["string", "null"]
    },
    "filename": {
      "type": "string"
    },
    "dest": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "dry_run", "downloaded", "skipped_exists", "not_found", "error"]
    },
    "media_type": {
      "type": "string"
    },
    "source_last_modified": {
      "type": ["string", "null"]
    },
    "source_last_modified_raw": {
      "type": ["string", "null"]
    },
    "fetched_at": {
      "type": "string"
    },
    "probed_at": {
      "type": "string"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "http_status": {
      "type": "integer"
    },
    "error": {
      "type": "string"
    }
  }
}
