{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CommonerLLP/commoner-probe/schemas/v1/question_list_row.json",
  "title": "Question List Row",
  "type": "object",
  "required": [
    "key",
    "kind",
    "house",
    "sitting_date",
    "list_type",
    "qno",
    "askers",
    "source_pdf",
    "extractor",
    "extracted_at"
  ],
  "properties": {
    "key": { "type": "string" },
    "kind": { "const": "question_list_row" },
    "house": { "type": "string", "enum": ["Lok Sabha", "Rajya Sabha"] },
    "sitting_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "list_type": { "type": "string" },
    "qno": { "type": "string" },
    "askers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "subject": { "type": "string" },
    "ministry": { "type": "string" },
    "text": { "type": "string" },
    "source_pdf": { "type": "string" },
    "extractor": { "type": "string" },
    "extracted_at": { "type": "string" }
  },
  "additionalProperties": true
}
