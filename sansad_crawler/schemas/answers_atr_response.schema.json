{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sreeramramasubramanian/sansad-crawler/schemas/v1/answers_atr_response.json",
  "title": "answers.jsonl — atr_response record",
  "description": "One recommendation/response pair extracted from an Action Taken Report PDF.",
  "type": "object",
  "required": ["key", "run_id", "source_pdf", "extracted_at", "language_classified", "source_report_type", "kind", "recommendation_no", "recommendation_text", "response_text", "confidence", "extractor"],
  "properties": {
    "key": { "type": "string" },
    "run_id": { "type": "string" },
    "source_pdf": { "type": "string" },
    "extracted_at": { "type": "string" },
    "language_classified": { "type": "array", "items": { "type": "string" } },
    "source_report_type": { "type": ["string", "null"] },
    "kind": { "type": "string", "const": "atr_response" },
    "recommendation_no": { "type": "integer" },
    "recommendation_text": { "type": "string" },
    "response_text": { "type": "string", "description": "Empty string when reply boundary not found in PDF" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "extractor": { "type": "string" }
  }
}
